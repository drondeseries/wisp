# wisp configuration — copy to .env and fill in.
# Only the two AIOStreams settings are required; everything else has a sensible
# default. Full reference: docs/Configuration.md

# ── AIOStreams (required) ────────────────────────────────────────────────────
# Your AIOStreams manifest URL (the uuid is read from it) and password. Leave the
# password blank only if your instance enables allowUnauthenticatedSearchApiRequests.
WISP_AIOSTREAMS_URL=https://your-aiostreams/stremio/<uuid>/<config>/manifest.json
WISP_AIOSTREAMS_PASSWORD=your-addon-password

# ── Self-mount ───────────────────────────────────────────────────────────────
# Where wisp mounts the library via embedded rclone (needs /dev/fuse + SYS_ADMIN).
# Unset it to serve HTTP only and mount it yourself.
WISP_MOUNT_PATH=/mnt/wisp
WISP_MOUNT_ALLOW_OTHER=true    # let a media-server container read it as another UID

# ── Notify your media server (optional) ──────────────────────────────────────
# On each pin/rename/delete, wisp tells the server to rescan. Set any combination;
# all are notified (fire-and-forget). Treat URLs/tokens as secrets.
#
# Silo (recommended) — Autoscan → Sources → Sonarr/Radarr Webhook → Generate URL:
WISP_NOTIFY_ARR_WEBHOOK_URL=
# Jellyfin / Emby — base URL + admin API key:
WISP_NOTIFY_JELLYFIN_URL=
WISP_NOTIFY_JELLYFIN_API_KEY=
WISP_NOTIFY_EMBY_URL=
WISP_NOTIFY_EMBY_API_KEY=
# Plex — base URL + X-Plex-Token (partial-scans the changed folder):
WISP_NOTIFY_PLEX_URL=
WISP_NOTIFY_PLEX_TOKEN=

# ── Release gating (optional, recommended for movies) ────────────────────────
# TMDB v3 key or v4 token gates movies on digital/physical release (no cams).
# Without it, wisp falls back to Cinemeta's release date.
WISP_TMDB_API_KEY=
WISP_TMDB_MARKETS=US,CA,GB,AU,DE,FR,IT,ES,JP,IN   # regions that count as released

# ── Advanced ─────────────────────────────────────────────────────────────────
WISP_LISTEN_ADDR=:8080
WISP_DB_PATH=/data/wisp.db          # pin + monitor database — persist this
WISP_LOG_LEVEL=info                 # debug | info | warn | error
WISP_SCHEDULE_INTERVAL=2h           # monitor re-check ceiling (wakes near airstamps anyway)
WISP_RESOLVE_CONCURRENCY=4          # episodes resolved in parallel per series (1-16); peak debrid fan-out
# VFS read chunk: smaller = less debrid over-fetch on seeks; larger = throughput.
WISP_READ_CHUNK_SIZE=32M
WISP_READ_CHUNK_SIZE_LIMIT=512M
