# wisp configuration — copy to .env and fill in.
# Only the two AIOStreams settings are required; everything else has a sensible
# default. See docs/Configuration.md for details.

# ── AIOStreams (required) ────────────────────────────────────────────────────
# Your AIOStreams manifest URL — the uuid is read from it automatically.
WISP_AIOSTREAMS_URL=https://your-aiostreams/stremio/<uuid>/<config>/manifest.json
# Your AIOStreams password (Search API Basic auth). Leave blank only if your
# instance enables allowUnauthenticatedSearchApiRequests.
WISP_AIOSTREAMS_PASSWORD=your-addon-password

# ── Self-mount (recommended) ─────────────────────────────────────────────────
# Where wisp mounts the library via embedded rclone. Needs /dev/fuse + SYS_ADMIN.
# Leave unset to serve HTTP only and mount it yourself.
WISP_MOUNT_PATH=/mnt/wisp
# Expose the mount to other UIDs (a media-server container reading it as another user).
WISP_MOUNT_ALLOW_OTHER=true

# ── Requests via Seerr (optional) ────────────────────────────────────────────
# Point an Overseerr/Jellyseerr webhook at POST /api/seerr. Set these so wisp can
# read a request's seasons and 4K flag authoritatively from the Seerr API.
WISP_SEERR_URL=http://seerr:5055
WISP_SEERR_API_KEY=

# ── Release gating (optional, recommended for movies) ────────────────────────
# TMDB v3 key or v4 token — gates movies on digital/physical release (no cams).
# Without it, wisp falls back to Cinemeta's release date.
WISP_TMDB_API_KEY=
# Regions whose TMDB digital/physical release makes a movie eligible (any one counts).
WISP_TMDB_MARKETS=US,CA,GB,AU,DE,FR,IT,ES,JP,IN

# ── Monitor scheduler ────────────────────────────────────────────────────────
# Fallback re-check ceiling. The scheduler otherwise wakes near the next known
# airstamp/release — it does not poll on a fixed tick.
WISP_SCHEDULE_INTERVAL=2h

# ── Silo integration (optional) ──────────────────────────────────────────────
# ARR-compatible Silo Autoscan webhook for instant import/rename/delete. Secret.
WISP_SILO_WEBHOOK_URL=

# ── Core / advanced ──────────────────────────────────────────────────────────
WISP_LISTEN_ADDR=:8080
WISP_DB_PATH=/data/wisp.db
WISP_LOG_LEVEL=info
# VFS read-chunk tuning: smaller = less debrid over-fetch on seeks; larger = throughput.
WISP_READ_CHUNK_SIZE=32M
WISP_READ_CHUNK_SIZE_LIMIT=512M
