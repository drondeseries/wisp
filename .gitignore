# ── Secrets: never commit real env or credential files ──────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*_rsa
*_ed25519
secrets.*
credentials.*

# ── Runtime data (pin + monitor database) ───────────────────────────────────
/data/
*.db
*.db-shm
*.db-wal

# ── Build artifacts ─────────────────────────────────────────────────────────
/wisp
/dist/
*.exe
*.test
*.out
coverage.*

# ── Editor / OS cruft ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
